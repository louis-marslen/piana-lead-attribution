# Token Private App HubSpot — scopes: crm.lists.read, crm.lists.write
HUBSPOT_TOKEN=pat-eu1-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ID de la liste master de prospection (visible dans l'URL de la liste dans l'UI)
MASTER_LIST_ID=12345

# Optionnel — région HubSpot (eu1 ou na1). Défaut: na1
HUBSPOT_REGION=eu1
